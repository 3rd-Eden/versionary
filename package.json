{
  "name": "@versionary/versionary",
  "version": "1.0.0",
  "description": "Manage multiple installed versions of a package in a dedicated store.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./types/versionary.d.ts",
      "default": "./src/versionary.js"
    }
  },
  "types": "./types/versionary.d.ts",
  "files": [
    "src",
    "types"
  ],
  "scripts": {
    "build:types": "tsc",
    "prepublishOnly": "npm run build:types",
    "test": "node --test --experimental-test-coverage --test-coverage-lines=90 --test-coverage-branches=90 test/unit/*.test.js test/integration/*.test.js"
  },
  "dependencies": {
    "@npmcli/arborist": "^9.1.4",
    "@npmcli/config": "^10.7.1",
    "npm-package-arg": "^12.0.2",
    "npm-registry-fetch": "^18.0.2",
    "pacote": "^21.0.0",
    "semver": "^7.7.2"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "typescript": "^5.9.3"
  }
}
